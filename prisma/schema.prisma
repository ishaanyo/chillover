generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  category      String
  price         Int
  originalPrice Int?
  description   String
  shortDesc     String
  fabric        String?
  fit           String?
  badge         String?
  isNew         Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  isBestseller  Boolean   @default(false)
  features      String[]  
  tags          String[]
  createdAt     DateTime  @default(now())

  images        Image[]
  variants      Variant[]
}

model Image {
  id        String  @id @default(cuid())
  url       String
  alt       String
  order     Int
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Variant {
  id        String  @id @default(cuid())
  size      String
  stock     Int
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}