generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  category      String
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  price         Int
  originalPrice Int?
  description   String
  shortDesc     String
  fabric        String?
  fit           String?
  badge         String?
  isNew         Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  isBestseller  Boolean   @default(false)
  features      String[]  
  tags          String[]
  createdAt     DateTime  @default(now())

  images        Image[]
  variants      Variant[]
}

model Subcategory {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  mainCategory String
  createdAt    DateTime  @default(now())

  products     Product[]
}

model Image {
  id        String  @id @default(cuid())
  url       String
  alt       String
  order     Int
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Variant {
  id        String  @id @default(cuid())
  size      String
  stock     Int
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Add an Enum for roles
enum Role {
  USER
  ADMIN
}

// Add the User model
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // We will hash this!
  role          Role      @default(USER) // Defaults to normal customer
  phone         String?
  dob           DateTime?
  gender        String?
  createdAt     DateTime  @default(now())

  orders        Order[]
  addresses     Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("Home")
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model StoreSettings {
  id                     String  @id @default("main")
  codEnabled             Boolean @default(true)

  // Delhivery shipping integration
  delhiveryEnabled       Boolean @default(false)
  delhiveryApiKey        String?
  delhiveryClientName    String?
  delhiveryPickupName    String?
  delhiveryPickupAddress String?
  delhiveryPickupCity    String?
  delhiveryPickupPincode String?
  delhiveryPickupPhone   String?
}

enum CouponType {
  PERCENT
  FLAT
}

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  type          CouponType
  value         Int
  minOrderValue Int        @default(0)
  maxDiscount   Int?
  expiresAt     DateTime?
  usageLimit    Int?
  usedCount     Int        @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  subtotal        Int
  shippingFee     Int         @default(0)
  couponCode      String?
  discountAmount  Int         @default(0)
  totalAmount     Int
  status          OrderStatus @default(PENDING)
  paymentMethod   String      @default("RAZORPAY")
  paymentId       String?
  shippingName    String
  shippingPhone   String
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String
  shippingPincode String

  // Delhivery shipment tracking
  waybill         String?
  trackingUrl     String?
  courierStatus   String?
  shippedAt       DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  productName  String
  productImage String?
  productSlug  String?
  size         String
  quantity     Int
  price        Int
}